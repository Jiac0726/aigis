<UserControl x:Class="ArcGisAiAssistant.AddIn.AiAssistantDockPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="360">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
      <TextBlock Text="{Binding Status}" FontWeight="SemiBold" VerticalAlignment="Center" />
      <CheckBox IsChecked="{Binding IsSandboxMode}" Content="安全模式"
                FontSize="11" Foreground="#666" Margin="12,0,0,0"
                VerticalAlignment="Center"
                ToolTip="开启后所有 AI 生成的输出写入独立沙箱 Geodatabase，保护原始数据" />
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="#D0D7DE" BorderThickness="1" Padding="8">
      <ListBox ItemsSource="{Binding Messages}"
               BorderThickness="0"
               HorizontalContentAlignment="Stretch"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>

    <TextBox Grid.Row="2"
             Margin="0,8,0,8"
             MinHeight="82"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto"
             Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" />

    <Expander Grid.Row="3" Header="对话历史" IsExpanded="False" Margin="0,4,0,4">
      <ListBox ItemsSource="{Binding TaskHistory}"
               MaxHeight="180"
               BorderThickness="0"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,2" Padding="6,4" CornerRadius="4"
                    Background="#F6F8FA" BorderBrush="#D0D7DE" BorderThickness="1">
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding TimeLabel}" FontSize="10" Foreground="#888" FontWeight="Bold" />
                  <Border CornerRadius="3" Padding="4,1" Margin="4,0,0,0">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Background" Value="#DCFFE4" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding StatusIcon}" Value="FAIL">
                            <Setter Property="Background" Value="#FFDCE0" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusIcon}" FontSize="9" FontWeight="Bold" />
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding DialogueText}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Expander>
      <ListBox ItemsSource="{Binding TaskHistory}"
               MaxHeight="140"
               BorderThickness="0"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding ShortSummary}"
                       FontSize="11"
                       Foreground="#666"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding DetailText}"
                       Margin="0,1" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Expander>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button MinWidth="96" Padding="12,6" Content="分析项目"
              Command="{Binding AnalyzeProjectCommand}" Margin="0,0,8,0" />
      <Button MinWidth="96" Padding="12,6" Content="Run"
              Command="{Binding SubmitCommand}" />
    </StackPanel>
  </Grid>
</UserControl>